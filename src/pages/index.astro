---
const GITHUB = 'https://github.com/kite-hq/kite';
const RELEASES = 'https://github.com/kite-hq/kite/releases';

const features = [
  {
    title: 'Light',
    body: 'No Chromium baggage. A small, fast desktop app built on Wails with the system WebView — not another 100 MB Electron bundle.',
  },
  {
    title: 'Git-friendly',
    body: 'Every request is a plain-text file. Version it, branch it, merge it — diff and review in PRs, and sync across machines with your own Git repo.',
  },
  {
    title: 'Cross-platform',
    body: 'macOS, Windows, and Linux. One client, native shells, the same plain-text collections everywhere.',
  },
  {
    title: 'Developer-first',
    body: 'A no-nonsense UI built for developers. Keyboard-first, local-first, no account required.',
  },
];
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32.png" />

    <title>Kite — The lightweight, Git-friendly API client</title>
    <meta
      name="description"
      content="Kite is a lightweight, cross-platform, open-source API client. Your requests live as plain text — diff them, review them, sync them with Git. Send it up the line."
    />

    <!-- Open Graph / social -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content="https://kite-hq.github.io" />
    <meta property="og:title" content="Kite — The lightweight, Git-friendly API client" />
    <meta
      property="og:description"
      content="A small, fast, open-source API client. Your requests live as plain text — diff, review, and sync them with Git. Send it up the line."
    />
    <meta property="og:image" content="https://kite-hq.github.io/og-icon.png" />
    <meta name="twitter:card" content="summary_large_image" />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&family=JetBrains+Mono:wght@400;500&display=swap"
      rel="stylesheet"
    />
  </head>

  <body>
    <!-- ── Nav ───────────────────────────────────────────── -->
    <header class="nav">
      <a class="brand" href="/" aria-label="Kite home">
        <img src="/logo.svg" width="32" height="32" alt="" />
        <span>kite</span>
      </a>
      <nav class="nav-links">
        <a href={GITHUB}>GitHub</a>
        <a class="btn btn-ghost" href={GITHUB}>Star on GitHub</a>
      </nav>
    </header>

    <main>
      <!-- ── Hero ────────────────────────────────────────── -->
      <section class="hero">
        <div class="hero-inner">
          <img class="hero-logo" src="/logo.svg" width="96" height="96" alt="Kite logo" />
          <h1>The lightweight,<br />Git-friendly API client.</h1>
          <p class="lead">
            Send it up the line. Your requests live as plain text — diff them,
            review them, sync them with Git.
          </p>
          <div class="cta-row">
            <a class="btn btn-primary" href={GITHUB}>Star on GitHub</a>
            <a class="btn btn-coral" href={RELEASES}>Download</a>
          </div>

          <!-- screenshot placeholder -->
          <div class="shot" role="img" aria-label="App screenshot coming soon">
            <span>screenshots coming soon</span>
          </div>
        </div>
      </section>

      <!-- ── Features ────────────────────────────────────── -->
      <section class="features" id="features">
        <div class="grid">
          {
            features.map((f) => (
              <article class="card">
                <h3>{f.title}</h3>
                <p>{f.body}</p>
              </article>
            ))
          }
        </div>
      </section>

      <!-- ── Why different ───────────────────────────────── -->
      <section class="why">
        <h2>Why Kite?</h2>
        <p>
          Postman and Bruno are great — and heavy. Kite stays small: a thin
          native shell instead of bundled Chromium, plain-text collections
          instead of a binary database, local-first instead of account-bound.
          You own your data, and Git is your sync.
        </p>
      </section>

      <!-- ── Quick start ─────────────────────────────────── -->
      <section class="install" id="install">
        <h2>Get started</h2>
        <p class="install-note">
          Grab a build from GitHub Releases. Packaged installers for macOS,
          Windows, and Linux are on the way.
        </p>
        <pre><code># open any folder of <span class="mono-accent">.kite</span> files as a collection
git clone your-api-collection
# … then point Kite at it</code></pre>
        <div class="cta-row">
          <a class="btn btn-primary" href={RELEASES}>Download</a>
          <a class="btn btn-ghost-dark" href={GITHUB}>View source</a>
        </div>
      </section>
    </main>

    <!-- ── Footer ──────────────────────────────────────── -->
    <footer class="footer">
      <div class="footer-inner">
        <img src="/wordmark.svg" height="34" alt="kite" />
        <nav class="footer-links">
          <a href={GITHUB}>GitHub</a>
          <a href={RELEASES}>Releases</a>
          <a href="https://github.com/kite-hq/kite/blob/main/LICENSE">MIT License</a>
        </nav>
      </div>
      <p class="copy">© kite-hq · send it up the line.</p>
    </footer>

    <style is:global>
      :root {
        --indigo: #4f5bd5;
        --indigo-deep: #2e388f;
        --sky: #afc0ff;
        --spar: #6e7be0;
        --coral: #ff9f45;
        --ink: #1a1a2e;
        --paper: #ffffff;
        --paper-2: #f6f7fc;
        --muted: #5b5f78;
        --radius: 14px;
      }

      * {
        box-sizing: border-box;
      }

      html {
        scroll-behavior: smooth;
      }

      body {
        margin: 0;
        font-family: Inter, -apple-system, BlinkMacSystemFont, 'Segoe UI', Arial,
          sans-serif;
        color: var(--ink);
        background: var(--paper);
        line-height: 1.55;
        -webkit-font-smoothing: antialiased;
      }

      h1,
      h2,
      h3 {
        line-height: 1.12;
        letter-spacing: -0.02em;
        margin: 0;
      }

      a {
        color: inherit;
        text-decoration: none;
      }

      /* ── Buttons ── */
      .btn {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        padding: 0.7rem 1.3rem;
        border-radius: 10px;
        font-weight: 600;
        font-size: 0.97rem;
        transition: transform 0.12s ease, background 0.12s ease, box-shadow 0.12s ease;
        border: 1px solid transparent;
        cursor: pointer;
      }
      .btn:hover {
        transform: translateY(-1px);
      }
      .btn-primary {
        background: var(--indigo);
        color: #fff;
        box-shadow: 0 6px 20px rgba(79, 91, 213, 0.35);
      }
      .btn-primary:hover {
        background: var(--indigo-deep);
      }
      .btn-coral {
        background: var(--coral);
        color: #2a1a06;
        box-shadow: 0 6px 20px rgba(255, 159, 69, 0.35);
      }
      .btn-coral:hover {
        background: #ff8f28;
      }
      .btn-ghost {
        background: rgba(255, 255, 255, 0.12);
        color: #fff;
        border-color: rgba(255, 255, 255, 0.3);
      }
      .btn-ghost:hover {
        background: rgba(255, 255, 255, 0.22);
      }
      .btn-ghost-dark {
        background: transparent;
        color: var(--indigo-deep);
        border-color: rgba(46, 56, 143, 0.3);
      }
      .btn-ghost-dark:hover {
        background: rgba(79, 91, 213, 0.08);
      }

      /* ── Nav ── */
      .nav {
        position: absolute;
        top: 0;
        left: 0;
        right: 0;
        z-index: 10;
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding: 1.1rem clamp(1rem, 5vw, 3rem);
      }
      .brand {
        display: flex;
        align-items: center;
        gap: 0.55rem;
        font-weight: 700;
        font-size: 1.3rem;
        color: #fff;
      }
      .nav-links {
        display: flex;
        align-items: center;
        gap: 1.2rem;
      }
      .nav-links > a:first-child {
        color: rgba(255, 255, 255, 0.85);
        font-weight: 500;
      }
      .nav-links > a:first-child:hover {
        color: #fff;
      }

      /* ── Hero ── */
      .hero {
        background: radial-gradient(
            1200px 600px at 50% -10%,
            #6470e6 0%,
            var(--indigo) 45%,
            var(--indigo-deep) 100%
          );
        color: #fff;
        padding: 8.5rem clamp(1rem, 5vw, 2rem) 4rem;
        text-align: center;
        overflow: hidden;
      }
      .hero-inner {
        max-width: 880px;
        margin: 0 auto;
      }
      .hero-logo {
        filter: drop-shadow(0 10px 30px rgba(0, 0, 0, 0.25));
        margin-bottom: 1.4rem;
      }
      .hero h1 {
        font-size: clamp(2.3rem, 6vw, 4rem);
        font-weight: 800;
      }
      .lead {
        font-size: clamp(1.05rem, 2.4vw, 1.3rem);
        color: var(--sky);
        max-width: 620px;
        margin: 1.3rem auto 0;
      }
      .cta-row {
        display: flex;
        gap: 0.8rem;
        justify-content: center;
        flex-wrap: wrap;
        margin-top: 2rem;
      }

      .shot {
        margin: 3.5rem auto 0;
        max-width: 820px;
        aspect-ratio: 16 / 9;
        border-radius: var(--radius);
        background: rgba(255, 255, 255, 0.06);
        border: 1px dashed rgba(255, 255, 255, 0.35);
        display: flex;
        align-items: center;
        justify-content: center;
      }
      .shot span {
        color: var(--sky);
        font-family: 'JetBrains Mono', monospace;
        font-size: 0.95rem;
        letter-spacing: 0.04em;
      }

      /* ── Features ── */
      .features {
        background: var(--paper-2);
        padding: clamp(3.5rem, 8vw, 6rem) clamp(1rem, 5vw, 2rem);
      }
      .grid {
        max-width: 1040px;
        margin: 0 auto;
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(230px, 1fr));
        gap: 1.2rem;
      }
      .card {
        background: var(--paper);
        border: 1px solid #e7e9f5;
        border-radius: var(--radius);
        padding: 1.6rem 1.5rem;
        transition: transform 0.15s ease, box-shadow 0.15s ease;
      }
      .card:hover {
        transform: translateY(-3px);
        box-shadow: 0 14px 34px rgba(46, 56, 143, 0.1);
      }
      .card h3 {
        font-size: 1.2rem;
        color: var(--indigo-deep);
        margin-bottom: 0.5rem;
      }
      .card p {
        margin: 0;
        color: var(--muted);
        font-size: 0.97rem;
      }

      /* ── Why ── */
      .why {
        max-width: 760px;
        margin: 0 auto;
        padding: clamp(3.5rem, 8vw, 6rem) clamp(1rem, 5vw, 2rem);
        text-align: center;
      }
      .why h2 {
        font-size: clamp(1.8rem, 4vw, 2.4rem);
        margin-bottom: 1rem;
      }
      .why p {
        color: var(--muted);
        font-size: 1.08rem;
        margin: 0;
      }

      /* ── Install ── */
      .install {
        background: var(--paper-2);
        text-align: center;
        padding: clamp(3.5rem, 8vw, 6rem) clamp(1rem, 5vw, 2rem);
      }
      .install h2 {
        font-size: clamp(1.8rem, 4vw, 2.4rem);
      }
      .install-note {
        color: var(--muted);
        max-width: 560px;
        margin: 1rem auto 1.8rem;
      }
      .install pre {
        max-width: 620px;
        margin: 0 auto 1.8rem;
        text-align: left;
        background: var(--ink);
        color: #e8e9f5;
        padding: 1.2rem 1.4rem;
        border-radius: var(--radius);
        overflow-x: auto;
        font-family: 'JetBrains Mono', monospace;
        font-size: 0.9rem;
        line-height: 1.7;
      }
      .mono-accent {
        color: var(--coral);
      }

      /* ── Footer ── */
      .footer {
        background: var(--ink);
        color: rgba(255, 255, 255, 0.7);
        padding: 2.5rem clamp(1rem, 5vw, 3rem);
      }
      .footer-inner {
        max-width: 1040px;
        margin: 0 auto;
        display: flex;
        align-items: center;
        justify-content: space-between;
        flex-wrap: wrap;
        gap: 1rem;
      }
      .footer-inner img {
        filter: brightness(0) invert(1);
        opacity: 0.92;
      }
      .footer-links {
        display: flex;
        gap: 1.4rem;
        flex-wrap: wrap;
      }
      .footer-links a:hover {
        color: #fff;
      }
      .copy {
        max-width: 1040px;
        margin: 1.6rem auto 0;
        font-size: 0.85rem;
        color: rgba(255, 255, 255, 0.45);
      }

      @media (max-width: 600px) {
        .nav-links > a:first-child {
          display: none;
        }
      }
    </style>
  </body>
</html>
